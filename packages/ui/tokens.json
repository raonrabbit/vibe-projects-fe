{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "vibe-projects design tokens — import into Figma via plugin",
  "palette": {
    "gray": {
      "0":   { "$value": "#ffffff", "$type": "color" },
      "50":  { "$value": "#f9fafb", "$type": "color" },
      "100": { "$value": "#f3f4f6", "$type": "color" },
      "200": { "$value": "#e5e7eb", "$type": "color" },
      "300": { "$value": "#d1d5db", "$type": "color" },
      "400": { "$value": "#9ca3af", "$type": "color" },
      "500": { "$value": "#6b7280", "$type": "color" },
      "600": { "$value": "#4b5563", "$type": "color" },
      "700": { "$value": "#374151", "$type": "color" },
      "800": { "$value": "#1f2937", "$type": "color" },
      "900": { "$value": "#111827", "$type": "color" },
      "950": { "$value": "#030712", "$type": "color" }
    },
    "emerald": {
      "50":  { "$value": "#ecfdf5", "$type": "color" },
      "100": { "$value": "#d1fae5", "$type": "color" },
      "300": { "$value": "#6ee7b7", "$type": "color" },
      "400": { "$value": "#34d399", "$type": "color" },
      "500": { "$value": "#10b981", "$type": "color" },
      "600": { "$value": "#059669", "$type": "color" },
      "700": { "$value": "#047857", "$type": "color" },
      "800": { "$value": "#065f46", "$type": "color" },
      "900": { "$value": "#064e3b", "$type": "color" }
    },
    "red": {
      "50":  { "$value": "#fef2f2", "$type": "color" },
      "500": { "$value": "#ef4444", "$type": "color" }
    },
    "yellow": {
      "50":  { "$value": "#fffbeb", "$type": "color" },
      "500": { "$value": "#f59e0b", "$type": "color" },
      "600": { "$value": "#d97706", "$type": "color" }
    }
  },
  "semantic": {
    "light": {
      "bg":                    { "$value": "{palette.gray.0}",      "$type": "color" },
      "bg-subtle":             { "$value": "{palette.gray.50}",     "$type": "color" },
      "surface":               { "$value": "{palette.gray.0}",      "$type": "color" },
      "surface-raised":        { "$value": "{palette.gray.50}",     "$type": "color" },
      "surface-overlay":       { "$value": "{palette.gray.100}",    "$type": "color" },
      "border":                { "$value": "{palette.gray.200}",    "$type": "color" },
      "border-strong":         { "$value": "{palette.gray.300}",    "$type": "color" },
      "text-primary":          { "$value": "{palette.gray.900}",    "$type": "color" },
      "text-secondary":        { "$value": "{palette.gray.500}",    "$type": "color" },
      "text-disabled":         { "$value": "{palette.gray.300}",    "$type": "color" },
      "text-inverse":          { "$value": "{palette.gray.0}",      "$type": "color" },
      "accent":                { "$value": "{palette.emerald.600}", "$type": "color" },
      "accent-hover":          { "$value": "{palette.emerald.700}", "$type": "color" },
      "accent-subtle":         { "$value": "{palette.emerald.50}",  "$type": "color" },
      "accent-foreground":     { "$value": "{palette.gray.0}",      "$type": "color" },
      "success":               { "$value": "{palette.emerald.600}", "$type": "color" },
      "success-subtle":        { "$value": "{palette.emerald.50}",  "$type": "color" },
      "success-foreground":    { "$value": "{palette.gray.0}",      "$type": "color" },
      "warning":               { "$value": "{palette.yellow.600}",  "$type": "color" },
      "warning-subtle":        { "$value": "{palette.yellow.50}",   "$type": "color" },
      "warning-foreground":    { "$value": "{palette.gray.900}",    "$type": "color" },
      "error":                 { "$value": "{palette.red.500}",     "$type": "color" },
      "error-subtle":          { "$value": "{palette.red.50}",      "$type": "color" },
      "error-foreground":      { "$value": "{palette.gray.0}",      "$type": "color" }
    },
    "dark": {
      "bg":                    { "$value": "{palette.gray.950}",    "$type": "color" },
      "bg-subtle":             { "$value": "{palette.gray.900}",    "$type": "color" },
      "surface":               { "$value": "{palette.gray.900}",    "$type": "color" },
      "surface-raised":        { "$value": "{palette.gray.800}",    "$type": "color" },
      "surface-overlay":       { "$value": "{palette.gray.700}",    "$type": "color" },
      "border":                { "$value": "{palette.gray.800}",    "$type": "color" },
      "border-strong":         { "$value": "{palette.gray.700}",    "$type": "color" },
      "text-primary":          { "$value": "{palette.gray.50}",     "$type": "color" },
      "text-secondary":        { "$value": "{palette.gray.400}",    "$type": "color" },
      "text-disabled":         { "$value": "{palette.gray.600}",    "$type": "color" },
      "text-inverse":          { "$value": "{palette.gray.900}",    "$type": "color" },
      "accent":                { "$value": "{palette.emerald.500}", "$type": "color" },
      "accent-hover":          { "$value": "{palette.emerald.400}", "$type": "color" },
      "accent-subtle":         { "$value": "{palette.emerald.900}", "$type": "color" },
      "accent-foreground":     { "$value": "{palette.gray.950}",    "$type": "color" },
      "success":               { "$value": "{palette.emerald.500}", "$type": "color" },
      "success-subtle":        { "$value": "#10b98120",             "$type": "color" },
      "success-foreground":    { "$value": "{palette.gray.950}",    "$type": "color" },
      "warning":               { "$value": "{palette.yellow.500}",  "$type": "color" },
      "warning-subtle":        { "$value": "#f59e0b1f",             "$type": "color" },
      "warning-foreground":    { "$value": "{palette.gray.900}",    "$type": "color" },
      "error":                 { "$value": "{palette.red.500}",     "$type": "color" },
      "error-subtle":          { "$value": "#ef44441f",             "$type": "color" },
      "error-foreground":      { "$value": "{palette.gray.0}",      "$type": "color" }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": { "$value": "Pretendard Variable, Pretendard, -apple-system, system-ui, sans-serif", "$type": "fontFamily" }
    },
    "fontSize": {
      "xs":   { "$value": "12px", "$type": "dimension" },
      "sm":   { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg":   { "$value": "18px", "$type": "dimension" },
      "xl":   { "$value": "20px", "$type": "dimension" },
      "2xl":  { "$value": "24px", "$type": "dimension" },
      "3xl":  { "$value": "30px", "$type": "dimension" },
      "4xl":  { "$value": "36px", "$type": "dimension" }
    },
    "lineHeight": {
      "tight":   { "$value": "1.25",  "$type": "number" },
      "snug":    { "$value": "1.375", "$type": "number" },
      "normal":  { "$value": "1.625", "$type": "number" },
      "relaxed": { "$value": "1.75",  "$type": "number" }
    }
  },
  "spacing": {
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "20": { "$value": "80px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" }
  },
  "borderRadius": {
    "sm":   { "$value": "4px",    "$type": "dimension" },
    "md":   { "$value": "8px",    "$type": "dimension" },
    "lg":   { "$value": "12px",   "$type": "dimension" },
    "xl":   { "$value": "16px",   "$type": "dimension" },
    "2xl":  { "$value": "20px",   "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "sm":  { "$value": "0 1px 2px 0 rgba(0,0,0,0.05)",                                                     "$type": "shadow" },
    "md":  { "$value": "0 4px 6px -1px rgba(0,0,0,0.08), 0 2px 4px -2px rgba(0,0,0,0.05)",                "$type": "shadow" },
    "lg":  { "$value": "0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.04)",              "$type": "shadow" }
  }
}
