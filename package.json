{
    "name": "frontend-vibe-projects",
    "private": true,
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "lint": "turbo lint",
        "type-check": "turbo type-check",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json,css,md,mdx}": "prettier --write"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "turbo": "latest"
    },
    "packageManager": "pnpm@9.0.0"
}
